{
  "name": "klods-js",
  "version": "2.9.0",
  "description": "Tiny, typed, lego-like builder API for klods components.",
  "license": "MIT",
  "author": "Drue Wilding",
  "repository": {
    "type": "git",
    "url": "https://github.com/druewilding/klods",
    "directory": "packages/klods-js"
  },
  "keywords": [
    "klods",
    "klods-js",
    "component",
    "builder"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "happy-dom": "^20.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  }
}
