{
  "name": "klods-js",
  "version": "3.4.0",
  "description": "Tiny, typed, lego-like builder API for klods components.",
  "keywords": [
    "builder",
    "component",
    "klods",
    "klods-js"
  ],
  "license": "MIT",
  "author": "Drue Wilding",
  "files": [
    "README.md",
    "dist"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "directory": "packages/klods-js",
    "type": "git",
    "url": "https://github.com/druewilding/klods"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "happy-dom": "20.9.0",
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "vitest": "4.1.7"
  }
}
